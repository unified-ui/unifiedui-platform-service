# ============================================
# Database Configuration (REQUIRED)
# ============================================
# PostgreSQL Database - at least one of DATABASE_URL or individual settings required
DATABASE_URL=postgresql://user:password@localhost:5432/unifiedui
# OR configure individually:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unifiedui
DB_USER=unifiedui
DB_PASSWORD=unifiedui_password

# ============================================
# Document Database Configuration (Optional)
# ============================================
DOCUMENT_DATABASE=MONGO_DB
MONGODB_CONNECTION_STRING=mongodb://localhost:27017
MONGODB_DATABASE_NAME=unifiedui

# ============================================
# Cache Configuration (Optional)
# ============================================
# Set to true to enable caching
CACHE_ENABLED=true
# Cache backend type (currently only REDIS supported)
CACHE_BACKEND=REDIS
# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_DEFAULT_TTL=3600

# ============================================
# Vault Configuration (Required for Credentials)
# ============================================
# Vault type: DOTENV (local dev), AZURE_KEYVAULT, or HASHICORP_VAULT
VAULT_TYPE=DOTENV

# Azure KeyVault (when VAULT_TYPE=AZURE_KEYVAULT)
# AZURE_KEYVAULT_VAULT_NAME=your-keyvault-name

# HashiCorp Vault (when VAULT_TYPE=HASHICORP_VAULT)
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=your-vault-token

# Secret Encryption Key (for caching secrets)
# Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=

# ============================================
# Service-to-Service Authentication
# ============================================
# Vault-based service keys (key names used by app vault)
# Generate both with: openssl rand -hex 32
PLATFORM_TO_AGENT_SERVICE_KEY=
AGENT_TO_PLATFORM_SERVICE_KEY=

# Separate vault types for app keys vs credential secrets (optional, defaults to VAULT_TYPE)
# APP_VAULT_TYPE=DOTENV
# SECRETS_VAULT_TYPE=HASHICORP_VAULT

# Agent Service Connection
AGENT_SERVICE_URL=http://localhost:8085
AGENT_SERVICE_TIMEOUT=30

# DEPRECATED: Use vault-based keys above instead
# X_AGENT_SERVICE_KEY=

# ============================================
# Identity / Token Validation (OBO Flow)
# ============================================
# Azure AD App Registration for token verification + OBO Graph token exchange.
# The frontend sends an API-scoped token (aud=api://{client_id}), the backend
# verifies it via JWKS and exchanges it for a Graph token using OBO.
#
# Setup:
# 1. App Registration → "Expose an API" → add scope "access_as_user"
# 2. App Registration → "Certificates & Secrets" → create a client secret
# 3. App Registration → "API Permissions" → add Graph delegated: User.Read,
#    User.ReadBasic.All, GroupMember.Read.All, Group.Read.All → Grant admin consent
# 4. Frontend MSAL scopes = ["api://{client_id}/access_as_user"]
IDENTITY_CLIENT_ID=your-app-registration-client-id
IDENTITY_CLIENT_SECRET=your-app-registration-client-secret
IDENTITY_TENANT_ID=your-azure-ad-tenant-id
IDENTITY_JWKS_URL=https://login.microsoftonline.com/common/discovery/v2.0/keys
IDENTITY_TOKEN_ALGORITHMS=["RS256"]
IDENTITY_VERIFY_SIGNATURE=true

# ============================================
# LDAP Identity Configuration (Optional)
# ============================================
# Required when using LDAP as identity provider.
# LDAP_BIND_DN and LDAP_BIND_PASSWORD are for the service account
# used for user/group directory lookups (not user login).
# LDAP_JWT_SECRET signs the JWT issued after successful LDAP bind.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
LDAP_SERVER_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=admin
LDAP_BASE_DN=dc=example,dc=com
LDAP_USE_SSL=false
LDAP_JWT_SECRET=
LDAP_USER_SEARCH_FILTER=(objectClass=person)
LDAP_GROUP_SEARCH_FILTER=(objectClass=groupOfNames)

# ============================================
# Generic OIDC Identity Configuration (Optional)
# ============================================
# Required when using a generic OIDC provider (e.g. Zitadel, Keycloak).
# Set OIDC_ISSUER_URL to match the "iss" claim in tokens.
OIDC_ISSUER_URL=http://localhost:8088
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
OIDC_JWKS_URL=http://localhost:8088/oauth/v2/keys
OIDC_USERINFO_URL=http://localhost:8088/oidc/v1/userinfo
OIDC_SCOPES=openid profile email

# ============================================
# File Storage Configuration (Optional)
# ============================================
# File storage backend: "local" or "azureblob"
# FILE_STORAGE_TYPE=local
# Local filesystem (when FILE_STORAGE_TYPE=local)
# FILE_STORAGE_LOCAL_BASE_PATH=/path/to/your/files
# Azure Blob Storage (when FILE_STORAGE_TYPE=azureblob, uses Managed Identity)
# FILE_STORAGE_AZURE_BLOB_ACCOUNT_URL=https://youraccount.blob.core.windows.net
# FILE_STORAGE_AZURE_BLOB_CONTAINER=unifiedui-files
# Max upload size in bytes (default: 25 MB)
# FILE_STORAGE_MAX_FILE_SIZE_BYTES=26214400

# ============================================
# System Admin Configuration
# ============================================
# At least one must be set. LDAP users: use SYSTEM_ADMIN_USERNAME.
# MSAL/OIDC users: use SYSTEM_ADMIN_EMAIL.
# When both are empty, any authenticated user can create organizations (not recommended for production).
SYSTEM_ADMIN_EMAIL=blub@example.com
SYSTEM_ADMIN_USERNAME=
